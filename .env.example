# ------------------------------------------------------------
# SLS-V2 environment config
# Copy to `.env` and fill in. Never commit real secrets.
# ------------------------------------------------------------

# Prisma / DB
DATABASE_URL="file:./dev.db"

# Storage backend: "mock" (local filesystem) or "sharepoint" (future)
STORAGE_BACKEND="mock"

# Mock backend: where files are written on disk (dev only)
MOCK_STORAGE_DIR="./storage"

# ------------------------------------------------------------
# SharePoint / Microsoft Graph (NOT yet wired up - placeholder)
# When you get approval, create an Entra ID app registration with
# the MINIMUM scopes needed for ONE drive/folder:
#   - Sites.Selected  (app-only, per-site grant)
#   - Files.ReadWrite.Selected
# Then grant the app access to ONLY the target site via:
#   POST /sites/{site-id}/permissions
# Do NOT grant Sites.ReadWrite.All or Files.ReadWrite.All - those
# give tenant-wide access.
# ------------------------------------------------------------
GRAPH_TENANT_ID=""
GRAPH_CLIENT_ID=""
GRAPH_CLIENT_SECRET=""
GRAPH_SITE_ID=""
GRAPH_DRIVE_ID=""
GRAPH_ROOT_FOLDER_ID=""

# ------------------------------------------------------------
# Auth (placeholder - dev mode uses an in-app user switcher)
# Later: wire to Microsoft Entra ID (Azure AD) via NextAuth or MSAL.
# ------------------------------------------------------------
AUTH_MODE="dev"
